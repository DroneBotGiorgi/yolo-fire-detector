{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Local Pipeline (YAML)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_experiment.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config",
        "${input:localPipelineConfigPath}"
      ]
    },
    {
      "name": "Dataset Generation Only (YAML)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run_generation.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--config",
        "${input:generationConfigPath}"
      ]
    },
    {
      "name": "Detect Webcam (Latest Export)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "webcam"
      ]
    },
    {
      "name": "Start Fake RTMP From Webcam 2",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/streaming/fake_rtmp_webcam.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--camera",
        "2"
      ]
    },
    {
      "name": "Detect Validation Images (Latest Export)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${workspaceFolder}/artifacts/local/datasets/smoke-dataset-4f999b314f/images/val",
        "--conf",
        "0.3"
      ]
    },
    {
      "name": "Detect Video File (Latest Export)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectVideoPath}"
      ]
    },
    {
      "name": "Detect Stream (Latest Export)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectStreamUrl}"
      ]
    },
    {
      "name": "Detect Fake RTMP Webcam 2",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "rtmp://127.0.0.1:1935/webcam2"
      ]
    },
    {
      "name": "Detect Image Folder (Latest Export)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/detect.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--source",
        "${input:detectImageFolder}"
      ]
    },
    {
      "name": "Create Cloud Bundle",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/cloud/prepare_cloud_bundle.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "--output",
        "dist/yolo-fire-detector-cloud.zip"
      ]
    },
    {
      "name": "Export Model To Drive Registry",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/model_registry/drive_model_sync.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "export",
        "--auth-mode",
        "oauth",
        "--registry-name",
        "${input:driveRegistryName}",
        "--drive-parent-id",
        "${input:googleDriveParentId}",
        "--oauth-credentials-file",
        "${input:googleOauthCredentialsFile}",
        "--local-persistent-root",
        "${input:localPersistentRoot}"
      ]
    },
    {
      "name": "Import Model From Drive Registry",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/tools/model_registry/drive_model_sync.py",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "args": [
        "import",
        "--auth-mode",
        "oauth",
        "--registry-name",
        "${input:driveRegistryName}",
        "--drive-parent-id",
        "${input:googleDriveParentId}",
        "--oauth-credentials-file",
        "${input:googleOauthCredentialsFile}",
        "--target-persistent-root",
        "${input:localPersistentRoot}",
        "--run-label",
        "${input:driveImportRunLabel}"
      ]
    }
  ],
  "inputs": [
    {
      "id": "localPipelineConfigPath",
      "type": "promptString",
      "description": "Path del file YAML per la pipeline locale completa",
      "default": "${workspaceFolder}/configs/local.default.yaml"
    },
    {
      "id": "generationConfigPath",
      "type": "promptString",
      "description": "Path del file YAML per la sola generazione dataset",
      "default": "${workspaceFolder}/configs/local.generate-only.yaml"
    },
    {
      "id": "detectVideoPath",
      "type": "promptString",
      "description": "Path del file video da analizzare"
    },
    {
      "id": "detectStreamUrl",
      "type": "promptString",
      "description": "URL RTMP/RTSP dello stream da analizzare"
    },
    {
      "id": "detectImageFolder",
      "type": "promptString",
      "description": "Cartella di immagini da analizzare"
    },
    {
      "id": "googleDriveRoot",
      "type": "promptString",
      "description": "Root locale Google Drive (solo filesystem mode, es. G:/My Drive)",
      "default": "G:/My Drive"
    },
    {
      "id": "googleDriveParentId",
      "type": "promptString",
      "description": "OAuth mode: folder ID parent su Google Drive (root = cartella principale)",
      "default": "root"
    },
    {
      "id": "googleOauthCredentialsFile",
      "type": "promptString",
      "description": "Path file locale credenziali OAuth (client_secrets + token)",
      "default": "${workspaceFolder}/tools/model_registry/oauth_credentials.local.json"
    },
    {
      "id": "driveRegistryName",
      "type": "promptString",
      "description": "Sottocartella registry modelli su Drive",
      "default": "yolo-fire-detector-models"
    },
    {
      "id": "localPersistentRoot",
      "type": "promptString",
      "description": "Root persistente locale per export/import",
      "default": "${workspaceFolder}/artifacts/local"
    },
    {
      "id": "driveImportRunLabel",
      "type": "promptString",
      "description": "Run label da importare (vuoto = latest)",
      "default": ""
    }
  ]
}
